# ── Conteúdo sensível: áudio de reunião nunca vai para o repositório ──
*.ogg
*.m4a
*.mp3
*.wav
*.flac
*.aac
# Pasta única de áudio de reunião (SPEC-008 §4). Ignora o conteúdo, versiona só
# o .gitkeep para a estrutura existir num clone. "Processado" deriva da saída em
# outputs/transcricoes/, não de mover de pasta.
data/audios/*
!data/audios/.gitkeep
fontes-audio/

# Golden set do eval: áudio + transcrição de referência (SPEC-005). Sensível,
# fora do Git por inteiro; só o sumário agregado de métricas (números, sem teor)
# é versionado, em docs/logs/ ou num REP.
data/golden/

# Nota pessoal de estudo, fora da taxonomia SERMI (não governada pelo gov-check).
# A cópia canônica vive em serminaro-governance/estudo/. Não versionada aqui.
aprender.md

# Saídas do pipeline (derivadas, podem conter conteúdo sensível)
outputs/

# Instâncias de inventário por reunião (SPEC-008): carregam nomes de
# participantes/jargão. Versiona-se só o template; instâncias ficam fora do Git.
data/configs/*.yml
data/configs/*.yaml
!data/configs/reuniao.template.yml

# ── Segredos e ambiente ──
.env
.envrc
# HF_TOKEN vive em variável de ambiente do conda, nunca em arquivo versionado

# ── Python ──
__pycache__/
*.pyc
*.pyo
.venv/
venv/
env/
*.egg-info/

# Artefatos de teste/cobertura (não versionados)
.coverage
.pytest_cache/

# ── Derivados de Markdown (gerados sob demanda, não versionados) ──
*.docx
*.pdf
dist/
# Exceção: assets podem conter PDF/DOCX legítimos
!docs/assets/**/*.pdf
!docs/assets/**/*.docx

# ── SO e editores ──
.DS_Store
Thumbs.db
desktop.ini
.vscode/
.idea/
*.swp
*.swo
*~

# ── Temporários ──
tmp/
*.tmp
*.log
